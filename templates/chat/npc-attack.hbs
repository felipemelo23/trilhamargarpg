<div class="trilhamarga chat-card npc-attack">
    <header class="card-header flexrow">
        <img src="{{actor.img}}" title="{{actor.name}}" width="36" height="36"/>
        <h3 class="actor-name">{{actor.name}}</h3>
    </header>

    <div class="card-content">
        <h4 class="attack-name">{{attackName}}</h4>
        {{#if description}}
        <div class="attack-description">{{{description}}}</div>
        {{/if}}
        
        <div class="dice-roll">
            {{{atkRollHtml}}}
        </div>

        {{#if critLabel}}
        <div class="atk-result {{resultClass}}">
            <strong>{{critLabel}}</strong>
        </div>
        {{/if}}

        <div class="damage-section">
            <div class="damage-header"><strong>{{localize "TRILHAMARGA.Damage"}}</strong></div>
            <div class="dice-roll">
                {{{dmgRollHtml}}}
            </div>
        </div>
    </div>
</div>