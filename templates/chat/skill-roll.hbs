<div class="trilhamarga chat-card skill-roll">
    <header class="card-header flexrow">
        <img src="{{actor.img}}" title="{{actor.name}}" width="36" height="36"/>
        <h3 class="actor-name">{{actor.name}}</h3>
    </header>

    <div class="card-content">
        <div class="skill-label">
            <em>
            {{#if chancesLabel}}
                {{localize "TRILHAMARGA.SkillCheckWithChances" skill=skillName chances=chancesLabel}}
            {{else}}
                {{localize "TRILHAMARGA.SkillCheck" skill=skillName}}
            {{/if}}
            </em>
        </div>
        {{#if flavorText}}<div class="flavor-text">{{flavorText}}</div>{{/if}}
        
        <div class="dice-roll">
            {{{rollHtml}}}
        </div>

        {{#if resultLabel}}
        <div class="skill-result {{resultClass}}">
            <strong>{{localize resultLabel}}</strong>
        </div>
        {{/if}}
    </div>
</div>